// 5)	23:19 - Is JavaScript Asynchronous? Prove with an example.

console.log("hi am 1st program");// This will execute immediately, demonstrating that JavaScript executes code synchronously by default
console.log("hi am 2nd program");
console.log("hi am 3rd program");
console.log("hi am 4th program");
setTimeout(function() // setTimeout is an asynchronous function that executes the callback after a specified delay
{
    console.log("hi am 5th program");   // This will execute after 2 seconds, demonstrating that JavaScript can handle asynchronous operations without blocking the main thread
}, 2000);

console.log("hi am 6th program");// This will execute immediately after the previous synchronous logs, showing that the asynchronous setTimeout does not block the execution of subsequent code

// Output:
// hi am 1st program
// hi am 2nd program
// hi am 3rd program
// hi am 4th program
// hi am 6th program
// (after 2 seconds) hi am 5th program